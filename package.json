{
  "name": "angular-sandbox",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "install": "npm ci --ignore-scripts",
    "start": "npm run serve",
    "serve": "ng serve --host 0.0.0.0 --port 4200 --poll 2000",
    "build": "ng build",
    "build:localize": "ng build --configuration production --localize",
    "serve:a11y": "ng serve --host 127.0.0.1 --port 4173 --poll 2000",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "lint": "ng lint",
    "i18n:extract": "ng extract-i18n --format=xlf2 --output-path src/locale --out-file messages.xlf",
    "a11y:ci": "start-server-and-test \"npm run serve:a11y\" http://127.0.0.1:4173/catalog \"pa11y-ci --config pa11yci.json\"",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" package.json eslint.config.js tsconfig*.json",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\" package.json eslint.config.js tsconfig*.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/animations": "21.2.0",
    "@angular/cdk": "21.2.0",
    "@angular/common": "21.2.0",
    "@angular/compiler": "21.2.0",
    "@angular/core": "21.2.0",
    "@angular/forms": "21.2.0",
    "@angular/localize": "21.2.0",
    "@angular/platform-browser": "21.2.0",
    "@angular/platform-server": "21.2.0",
    "@angular/router": "21.2.0",
    "@angular/ssr": "21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.0",
    "@angular/cli": "21.2.0",
    "@angular/compiler-cli": "21.2.0",
    "@types/node": "24.5.2",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "jsdom": "^27.1.0",
    "pa11y-ci": "^4.0.1",
    "prettier": "^3.6.2",
    "start-server-and-test": "^2.1.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8"
  }
}
